# ─── Application ────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=example.ai
COMING_SOON=true                  # Remove or set to "false" when ready to launch the full site

# ─── Clerk Authentication ───────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ─── MongoDB ────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/dbname

# ─── Stripe Payments ───────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRODUCT_ID=prod_xxx
STRIPE_PRICE_ID=price_xxx

# ─── OpenAI (GPT-5) ────────────────────────────────────────────
OPENAI_API_KEY=sk-xxx

# ─── GitHub (reference only, not used at runtime) ──────────────
# GITHUB_REPO=RocketingAI/www-example-ai

# ─── Vercel (reference only) ───────────────────────────────────
# VERCEL_PROJECT_ID=prj_xxx

# ─── Rocketing Platform SDK ───────────────────────────────────────
ROCKETING_APP_SLUG=                        # App identifier (e.g., "graders-ai")
ROCKETING_API_KEY=                         # Platform API key for hub handshake
ROCKETING_SECRETS_API_KEY=                 # Secrets service API key

# ─── Rocketing Platform (Optional — cascade data lookup) ─────────
# PLATFORM_MONGODB_URI=mongodb+srv://...    # Platform cluster for ?app= cascade lookup

# ─── Rocketing Registry (Optional) ─────────────────────────────
# ROCKETING_REGISTRY_API_KEY=xxx
# ROCKETING_REGISTRY_URL=https://registry.rocketing.ai/api
