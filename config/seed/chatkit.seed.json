{
  "_meta": {
    "configType": "chatkit",
    "version": "2.0.0",
    "starterTemplate": "rocketing-mvp-starter",
    "description": "ChatKit AI assistant — flat structure aligned with builder's ChatContainerConfig",
    "agentTask": "configureChatkit",
    "cascadeScope": [
      "trigger",
      "sector1",
      "sector17"
    ],
    "dependsOn": [
      "site"
    ],
    "notes": "Flat structure matches builder.rocketing.ai/chatkit/ui output. Extra fields (archetype, model, reasoning, tone, registry*) are cascade-specific."
